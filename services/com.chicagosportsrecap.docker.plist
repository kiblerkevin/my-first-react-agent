<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chicagosportsrecap.docker</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>
            # Wait for Docker Desktop to be ready
            for i in $(seq 1 60); do
                if /opt/homebrew/bin/docker info > /dev/null 2>&amp;1; then
                    break
                fi
                sleep 5
            done
            cd /Users/kevin/Projects/my-first-react-agent
            /opt/homebrew/bin/docker compose up -d
        </string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/kevin/Projects/my-first-react-agent/logs/docker_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kevin/Projects/my-first-react-agent/logs/docker_stderr.log</string>
</dict>
</plist>
