<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.chicagosportsrecap.approval-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>
            # Wait for Docker/Langfuse to be ready
            for i in $(seq 1 90); do
                if curl -s http://localhost:3000/api/public/health > /dev/null 2>&amp;1; then
                    break
                fi
                sleep 5
            done
            cd /Users/kevin/Projects/my-first-react-agent
            exec caffeinate -s /Users/kevin/Projects/my-first-react-agent/venv/bin/python server/approval_server.py
        </string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/kevin/Projects/my-first-react-agent</string>

    <key>StandardOutPath</key>
    <string>/Users/kevin/Projects/my-first-react-agent/logs/approval_server_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kevin/Projects/my-first-react-agent/logs/approval_server_stderr.log</string>
</dict>
</plist>
